generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Appointment {
  id                String   @id
  ticketNumber      Int      @unique @default(autoincrement())
  driverName        String
  vehicleNumber     String
  appointmentDate   DateTime @db.Date
  vacationStartDate DateTime? @db.Date
  vacationEndDate   DateTime? @db.Date
  permitType        String   @default("")
  permitStartDate   DateTime? @db.Date
  permitEndDate     DateTime? @db.Date
  permitDate        DateTime? @db.Date
  permitStartTime   String   @default("")
  permitEndTime     String   @default("")
  appointmentReason String
  email             String
  phone             String
  assignedExecutive String   @default("")
  scheduledStartTime String @default("")
  scheduledEndTime   String @default("")
  status            String   @default("pendiente")
  dateChangePending Boolean  @default(false)
  dateChangeMessage String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([assignedExecutive])
  @@index([appointmentReason])
  @@index([createdAt])
}

model AppointmentReason {
  id                         String   @id @default(uuid())
  value                      String   @unique
  label                      String
  allowsExecutiveAssignment  Boolean  @default(false)
  usesAppointmentDuration    Boolean  @default(false)
  appointmentDurationMinutes Int      @default(30)
  usesServiceStartTime       Boolean  @default(false)
  serviceStartTime           String   @default("")
  usesDateRange              Boolean  @default(false)
  usesPermitDetails          Boolean  @default(false)
  isActive                   Boolean  @default(true)
  restrictedWeekdays         String   @default("")
  requiresBusinessDayAdvance Boolean  @default(false)
  businessDaysAdvance        Int      @default(0)
  weekdayBusinessAdvance     String   @default("")
  sortOrder                  Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model Executive {
  id                String   @id @default(uuid())
  name              String   @unique
  email             String   @default("")
  isActive          Boolean  @default(true)
  dailyLimitEnabled Boolean  @default(false)
  dailyLimitMax     Int?
  lunchBreakEnabled Boolean  @default(false)
  lunchBreakStart   String   @default("")
  lunchBreakEnd     String   @default("")
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model DriverOwner {
  id                     String    @id @default(uuid())
  vehicleNumber          String    @unique
  fullName               String
  email                  String    @default("")
  rut                    String    @default("")
  licenseExpiryDate      DateTime? @db.Date
  birthDate              DateTime? @db.Date
  landlinePhone          String    @default("")
  mobilePhone            String    @default("")
  address                String    @default("")
  recordStatus           String    @default("V")
  isConductor            Boolean   @default(false)
  isPropietario          Boolean   @default(false)
  municipalLicense       String    @default("")
  shifts                 String    @default("")
  emergencyContactName   String    @default("")
  emergencyContactEmail  String    @default("")
  emergencyContactPhone  String    @default("")
  licensePlate           String    @default("")
  inspectionExpiryDate   DateTime? @db.Date
  vehicleType            String    @default("")
  subscriptionDate       DateTime? @db.Date
  passwordHash           String?
  tempPasswordSentAt     DateTime?
  mustChangePassword     Boolean   @default(false)
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([isActive])
  @@index([fullName])
  @@index([recordStatus])
  @@index([licensePlate])
}

model Propietario {
  id                    String    @id @default(uuid())
  importKey             String    @unique
  vehicleNumber         String    @default("")
  fullName              String
  firstName             String    @default("")
  lastName              String    @default("")
  secondLastName        String    @default("")
  rut                   String    @default("")
  email                 String    @default("")
  landlinePhone         String    @default("")
  mobilePhone           String    @default("")
  address               String    @default("")
  postalCode            String    @default("")
  city                  String    @default("")
  province              String    @default("")
  bankName              String    @default("")
  bankAccount           String    @default("")
  accountHolder         String    @default("")
  titularRut            String    @default("")
  titularEmail          String    @default("")
  titularBankName       String    @default("")
  titularBankAccount    String    @default("")
  bankBic               String    @default("")
  paymentMethod         String    @default("")
  paymentDay            String    @default("")
  notes                 String    @default("")
  branchOffice          String    @default("")
  area                  String    @default("")
  costCenter            String    @default("")
  accountingAccount     String    @default("")
  isVip                 Boolean   @default(false)
  gender                String    @default("")
  recordStatus          String    @default("V")
  licenseExpiryDate     DateTime? @db.Date
  birthDate             DateTime? @db.Date
  incorporationDate     DateTime? @db.Date
  deactivationDate      DateTime? @db.Date
  emergencyContactName  String    @default("")
  emergencyContactEmail String    @default("")
  emergencyContactPhone String    @default("")
  isActive              Boolean   @default(true)
  inactiveReason          String    @default("")
  activationReason        String    @default("")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([isActive])
  @@index([fullName])
  @@index([rut])
}

model PropietarioBank {
  id        String   @id @default(uuid())
  name      String   @unique
  bankBic   String   @default("")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
}

model Holiday {
  id                  String   @id @default(uuid())
  date                DateTime @unique @db.Date
  name                String
  year                Int
  scope               String   @default("nacional")
  businessDaysAdvance Int      @default(15)
  isActive            Boolean  @default(true)
  source              String   @default("manual")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([year])
  @@index([isActive])
}

model AccessUser {
  id                 String    @id @default(uuid())
  email              String    @unique
  fullName           String    @default("")
  passwordHash       String?
  isSuperAdmin       Boolean   @default(false)
  mustChangePassword Boolean   @default(false)
  tempPasswordSentAt DateTime?
  isActive           Boolean   @default(true)
  canSolicitudes     Boolean   @default(false)
  canCalendario      Boolean   @default(false)
  canMotivos         Boolean   @default(false)
  canEjecutivos      Boolean   @default(false)
  canConductores     Boolean   @default(false)
  canPropietarios    Boolean   @default(false)
  canPagoPropietario Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([isActive])
  @@index([isSuperAdmin])
}
