# Copia este archivo como `.env` y completa los valores reales.
# Nunca subas `.env` al repositorio.

# Super administrador de accesos (se crea en BD al primer login)
ACCESS_SUPER_ADMIN_EMAIL=fmorillo@transportesapoquindo.cl
ACCESS_SUPER_ADMIN_TEMP_PASSWORD=1818

# Acceso administrador legacy (agendamientos, acceso total)
ADMIN_USER=ejecutivo
ADMIN_PASSWORD=12345678

# Firma de sesión admin (recomendado: cadena aleatoria larga)
SESSION_SECRET=

# SMTP citas / agendamientos / claves temporales (cPanel, no Office 365)
CITAS_SMTP_HOST=mail.transporteapoquindo.cl
CITAS_SMTP_PORT=465
CITAS_SMTP_USER=cita@transporteapoquindo.cl
CITAS_SMTP_PASSWORD=
CITAS_EMAIL_FROM=cita@transporteapoquindo.cl

# Alias legacy (opcional; CITAS_SMTP_* tiene prioridad)
SMTP_HOST=mail.transporteapoquindo.cl
SMTP_PORT=465
SMTP_USER=cita@transporteapoquindo.cl
SMTP_PASSWORD=
EMAIL_FROM=cita@transporteapoquindo.cl

# Destinatarios de alertas del módulo Propietarios (opcional, separados por coma)
# PROPIETARIOS_NOTIFY_EMAILS=fmorillo@transportesapoquindo.cl,maneva@transportesapoquindo.cl,administracion@transportesapoquindo.cl

# SMTP exclusivo para Pago propietario (cPanel)
PAGO_SMTP_HOST=mail.transporteapoquindo.cl
PAGO_SMTP_PORT=465
PAGO_SMTP_USER=
PAGO_SMTP_PASSWORD=
PAGO_EMAIL_FROM=

# Base de datos
DATABASE_URL=

# URL pública de producción (enlaces en correos de acceso y notificaciones)
NEXT_PUBLIC_APP_URL=https://flota-apoquindo.vercel.app
