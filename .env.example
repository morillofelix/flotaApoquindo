# Copia este archivo como `.env` y completa los valores reales.
# Nunca subas `.env` al repositorio.

# Acceso administrador (agendamientos)
ADMIN_USER=
ADMIN_PASSWORD=

# Firma de sesión admin (recomendado: cadena aleatoria larga)
SESSION_SECRET=

# SMTP agendamientos / citas
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# SMTP exclusivo para Pago propietario (cPanel)
PAGO_SMTP_HOST=mail.transporteapoquindo.cl
PAGO_SMTP_PORT=465
PAGO_SMTP_USER=
PAGO_SMTP_PASSWORD=
PAGO_EMAIL_FROM=

# Base de datos
DATABASE_URL=
